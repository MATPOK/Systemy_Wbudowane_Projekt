\newcommand\@myauthor{}
\renewcommand\author[1]{\renewcommand\@myauthor{#1}}

\newcommand\@myid{}
\newcommand\studentID[1]{\renewcommand\@myid{#1}}

\newcommand\@mytitle{}
\renewcommand\title[1]{\renewcommand\@mytitle{#1}}

\newcommand\@mycourse{}
\newcommand\course[1]{\renewcommand\@mycourse{#1}}

\newcommand\@mytype{Sprawozdanie} 
\newcommand\type[1]{\renewcommand\@mytype{#1}}

% Ścieżka do loga (domyślnie szuka w folderze figures lub głównym)
\newcommand\@logopath{figures/logoweii.jpg}
\newcommand\setlogopath[1]{\renewcommand\@logopath{#1}}

\renewcommand{\maketitle}{
    \begin{titlepage}
        \begin{center}
            % LOGO - musi być plik logoweii.jpg
            \vspace*{1cm}
            \IfFileExists{\@logopath}{
                \includegraphics[width=12.5cm]{\@logopath}
            }{
                \vspace*{2cm}
                \textbf{[BRAK PLIKU LOGA: \@logopath]} \\
                \textit{Wgraj plik logoweii.jpg do folderu figures}
                \vspace*{2cm}
            }
            
            \vspace{4cm}
            
            {\Huge \textbf{\@mytype}} 
    
            
            {\Large \textbf{\@mycourse}}
            \vspace{1cm}
            
            {\Large ``\@mytitle''}
            \vspace{1cm}
            
            {\Large \textbf{\@myauthor}} \\
            {\large \@myid} 
            
            \vfill
            
            {\large Rzeszów, \the\day.\the\month.\the\year}
        \end{center}
    \end{titlepage}
}

