% 2. KONFIGURACJA WYGLĄDU (FORMATOWANIE WEII)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Interlinia 1.5
\linespread{1.5}

% Wcięcie akapitowe 1.25 cm
\setlength\parindent{1.25cm}

% Konfiguracja list (zgodnie ze starym wzorem: myślniki, wcięcia)
\setlist[enumerate,1]{label=\arabic*), leftmargin=1.25cm, itemsep=0pt, topsep=0pt}
\setlist[itemize,1]{label={--}, labelsep=0.4cm, leftmargin=1.25cm, itemsep=0pt, topsep=0pt}
\setlist[itemize,2]{label={--}, labelsep=0.4cm, leftmargin=0.6cm, itemsep=0pt, topsep=0pt}

% Kolory do kodów źródłowych
\definecolor{codegreen}{rgb}{0,0.6,0}
\definecolor{codegray}{rgb}{0.5,0.5,0.5}
\definecolor{codepurple}{rgb}{0.58,0,0.82}
\definecolor{backcolour}{rgb}{0.95,0.95,0.92}

% Ustawienia listingu (kodu)
\lstset{
    backgroundcolor=\color{white},
    commentstyle=\color{codegreen},
    keywordstyle=\color{blue},
    numberstyle=\tiny\color{codegray},
    stringstyle=\color{codepurple},
    basicstyle=\ttfamily\footnotesize\linespread{1}\selectfont, % Mniejsza interlinia w kodzie
    breakatwhitespace=false,         
    breaklines=true,                 
    captionpos=t,                    
    keepspaces=true,                 
    numbers=left,                    
    numbersep=5pt,                  
    showspaces=false,                
    showstringspaces=false,
    showtabs=false,                  
    tabsize=2,
    frame=single,
    rulecolor=\color{black},
    inputencoding=utf8,
    extendedchars=true,
    literate={ą}{{\k{a}}}1 {ć}{{\'c}}1 {ę}{{\k{e}}}1 {ł}{{\l{}}}1 {ń}{{\'n}}1 {ó}{{\'o}}1 {ś}{{\'s}}1 {ż}{{\.z}}1 {ź}{{\'z}}1
}

% Numeracja obiektów z uwzględnieniem rozdziału (np. Rys. 2.1)
\AtBeginDocument{
    \counterwithin{lstlisting}{section}
    \counterwithin{figure}{section}
    \counterwithin{table}{section}
    \counterwithin{equation}{section}
}

% Pusta strona (komenda pomocnicza)
\newcommand\blankpage{
    \null
    \thispagestyle{empty}
    \newpage
}

